# =========================================================================
# InterviewAI Production Environment Variables Template
# =========================================================================
# Copy this file to a new file named '.env' for local development,
# and use these keys to configure the environment variables inside your Render dashboard.

# Server Settings
PORT=3000
NODE_ENV=production
JWT_SECRET=your_secure_random_jwt_secret_key_here

# Database Settings
MONGO_URI=mongodb+srv://<db_user>:<db_password>@your-cluster.mongodb.net/your-db-name

# AI Integrations
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here
INTERVIEW_REPORT_URL=sumanta795/interviewprep-ai

# CORS & Separate Service Configurations (Only required if deploying separately)
# FRONTEND_URL=https://your-frontend-domain.onrender.com,http://localhost:5173

# Puppeteer Deployment Configurations (Important for Render environments)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
PUPPETEER_CACHE_DIR=/opt/render/project/src/.cache/puppeteer
